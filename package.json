{
  "name": "@webgazer-ts/monorepo",
  "version": "0.2.0",
  "private": true,
  "description": "Webgazer.ts monorepo - Eye tracking for JavaScript and React",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm --filter @webgazer-ts/core build && pnpm --filter @webgazer-ts/react build && pnpm --filter webgazer-ts build",
    "build:core": "pnpm --filter @webgazer-ts/core build",
    "build:react": "pnpm --filter @webgazer-ts/react build",
    "typecheck:types": "pnpm --filter @webgazer-ts/core build:types && pnpm --filter @webgazer-ts/react build:types",
    "typecheck:core": "packages/core/node_modules/.bin/tsc --noEmit -p packages/core/tsconfig.json",
    "typecheck:react": "packages/react/node_modules/.bin/tsc --noEmit -p packages/react/tsconfig.json",
    "typecheck:facade": "packages/core/node_modules/.bin/tsc --noEmit -p packages/webgazer-ts/tsconfig.json",
    "typecheck:example": "examples/react-demo/node_modules/.bin/tsc --noEmit -p examples/react-demo/tsconfig.json",
    "typecheck": "pnpm run typecheck:types && pnpm run typecheck:core && pnpm run typecheck:react && pnpm run typecheck:facade && pnpm run typecheck:example",
    "test": "pnpm --filter @webgazer-ts/core test --run && pnpm --filter @webgazer-ts/react test --run",
    "ci:test": "bash scripts/ci-test.sh",
    "ci:build": "bash scripts/ci-build.sh",
    "ci:verify": "bash scripts/ci-test.sh && bash scripts/ci-build.sh",
    "examples:build": "pnpm --filter webgazer-react-demo build",
    "dev": "pnpm --filter @webgazer-ts/core dev",
    "dev:react": "pnpm --filter @webgazer-ts/react dev",
    "clean": "pnpm --filter @webgazer-ts/core clean && pnpm --filter @webgazer-ts/react clean",
    "docs:dev": "vitepress dev docs-site",
    "docs:build": "pnpm run docs:api && vitepress build docs-site",
    "docs:preview": "vitepress preview docs-site",
    "docs:api": "pnpm run docs:api:core && pnpm run docs:api:react",
    "docs:api:core": "typedoc --options docs-site/typedoc.core.json",
    "docs:api:react": "typedoc --options docs-site/typedoc.react.json"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "eye-tracking",
    "webgazer",
    "typescript",
    "react",
    "gaze-prediction",
    "monorepo"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jhndrncrz/webgazer-ts.git"
  },
  "homepage": "https://webgazer.cs.brown.edu",
  "bugs": {
    "url": "https://github.com/jhndrncrz/webgazer-ts/issues"
  },
  "devDependencies": {
    "typedoc": "^0.28.14",
    "typedoc-plugin-markdown": "^4.9.0",
    "vitepress": "^1.6.4"
  }
}
