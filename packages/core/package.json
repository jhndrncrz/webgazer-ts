{
  "name": "@webgazer-ts/core",
  "version": "0.2.0",
  "description": "TypeScript rewrite of Webgazer.js - Webcam eye tracking for academic research (NOT for production use)",
  "type": "module",
  "license": "GPL-3.0-or-later",
  "author": {
    "name": "John Adrian Cruz"
  },
  "contributors": [
    {
      "name": "Original Webgazer.js Team",
      "url": "https://webgazer.cs.brown.edu"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jhndrncrz/webgazer-ts.git",
    "directory": "packages/core"
  },
  "keywords": [
    "eye-tracking",
    "webgazer",
    "typescript",
    "gaze-prediction",
    "webcam",
    "tensorflow",
    "face-detection",
    "academic",
    "research",
    "thesis"
  ],
  "main": "./dist/webgazer-ts.umd.cjs",
  "module": "./dist/webgazer-ts.js",
  "browser": "./dist/webgazer.js",
  "unpkg": "./dist/webgazer.js",
  "jsdelivr": "./dist/webgazer.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": "./dist/webgazer-ts.js",
      "node": "./ssr.js",
      "import": "./dist/webgazer-ts.js",
      "require": "./dist/webgazer-ts.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "ssr.js",
    "ssr.cjs",
    "ssr.d.ts",
    "README.md",
    "LICENSE.md",
    "CREDITS.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --declaration --emitDeclarationOnly --outDir dist",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist",
    "build:bundle": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@tensorflow-models/face-landmarks-detection": "^1.0.6",
    "@tensorflow/tfjs": "^4.22.0",
    "localforage": "^1.10.0",
    "regression": "2.0.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^27.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=16.0.0"
  },
  "homepage": "https://jhndrncrz.github.io/webgazer-ts/",
  "bugs": {
    "url": "https://github.com/jhndrncrz/webgazer-ts/issues"
  }
}
